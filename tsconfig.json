{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "astro.config.mjs",
    "vitest.config.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": ["dist", "public", "testing", ".claude"]
}
