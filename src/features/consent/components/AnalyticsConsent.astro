---
import { Button } from '@/components/ui';
import { copy } from '../../../lib/copy';

interface Props {
  enabled: boolean;
  measurementId: string;
}

const { enabled, measurementId } = Astro.props;
---

{
  enabled ? (
    <>
      <div
        class="pointer-events-none fixed inset-x-0 bottom-0 z-9999 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom,0px))]"
        data-analytics-consent
        data-measurement-id={measurementId}
        hidden
        role="region"
        aria-label={copy.consent.regionLabel}
      >
        <div class="consent-banner-panel anim-float-in pointer-events-auto mx-auto grid w-full max-w-5xl gap-4 rounded-(--radius-panel) border p-6 shadow-float md:grid-cols-(--layout-grid-landing-footer) md:items-end">
          <div class="grid min-w-0 gap-3.5">
            <div class="consent-banner-eyebrow text-content text-note inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1.5 font-mono leading-4 tracking-(--tracking-ui-wide) uppercase">
              <span class="bg-success inline-flex size-2 rounded-full" aria-hidden="true"></span>
              {copy.consent.eyebrow}
            </div>

            <div class="grid max-w-2xl gap-2">
              <h2 class="text-content leading-reading text-lg font-semibold text-pretty">
                {copy.consent.heading}
              </h2>
              <p class="text-content-muted text-xs leading-6 sm:text-sm">{copy.consent.body}</p>
            </div>
          </div>

          <div class="flex flex-wrap items-center justify-stretch gap-3 md:justify-end [&_button]:flex-1 md:[&_button]:flex-none lg:flex-col">
            <Button
              data-consent-decline
              variant="secondary"
            >
              {copy.consent.decline}
            </Button>
            <Button
              data-consent-accept
              variant="primary"
            >
              {copy.consent.accept}
            </Button>
          </div>
        </div>
      </div>

      <script>
        import { initAnalyticsConsent } from '../initAnalyticsConsent';

        const banner = document.querySelector('[data-analytics-consent]');
        if (banner instanceof HTMLElement) {
          initAnalyticsConsent(banner);
        }
      </script>
    </>
  ) : null
}
