---
import { limitsSection, limitStats } from '../data';

const eyebrowClass =
  'font-mono text-caption leading-4 tracking-eyebrow uppercase text-content-subtle';
---

<section id="limits" class="border-border border-t">
  <div class="layout-shell py-16 sm:pb-20">
    <div class="grid gap-6 md:grid-cols-(--layout-grid-landing-limits) md:items-end">
      <div>
        <div class:list={[eyebrowClass, 'mb-2.5']}>{limitsSection.eyebrow}</div>
        <h2 class="max-w-measure-landing-limits text-title-card tracking-tight-card">
          {limitsSection.title}
        </h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {
          limitStats.map((stat) => (
            <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-4">
              <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                {stat.label}
              </span>
              <span class="text-content tracking-tight-section mt-2 block text-xl font-medium">
                {stat.value}
              </span>
              <span class="text-content-subtle text-note mt-1 block leading-4">{stat.note}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
