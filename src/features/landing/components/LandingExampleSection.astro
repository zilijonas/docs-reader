---
interface Props {
  baseUrl: string;
  variant?: "landing" | "marketing";
}

const { baseUrl, variant = "landing" } = Astro.props;

const notes = [
  {
    label: "Page preview",
    text: "See the PDF page and highlighted areas before anything is exported.",
  },
  {
    label: "Review queue",
    text: "Check suggested detections one by one and keep only what should be redacted.",
  },
  {
    label: "Manual control",
    text: "Add your own redactions when the document needs extra cleanup.",
  },
] as const;
---

{
  variant === "landing" ? (
    <section class="landing-section-shell landing-example-section">
      <div class="page-container section-space landing-example-shell">
        <div class="landing-section-head">
          <div>
            <div class="landing-eyebrow mb-3">Example</div>
            <h2 class="type-display-section measure-landing-section">
              Review workspace. Clear page view. Final decision stays with you.
            </h2>
          </div>
          <p class="landing-section-copy type-body">
            The app shows the page, suggested redactions, and manual tools in one place so you can inspect every change before export.
          </p>
        </div>

        <div class="landing-example-grid">
          <div class="landing-card landing-example-frame">
            <picture>
              <source srcset={`${baseUrl}example.webp`} type="image/webp" />
              <img
                alt="Example of the HDDN redaction review workspace with a PDF preview, highlighted detections, and a review sidebar."
                class="landing-example-image"
                height="1024"
                loading="lazy"
                src={`${baseUrl}example.png`}
                width="1536"
              />
            </picture>
          </div>

          <div class="landing-example-notes" aria-label="Example highlights">
            {notes.map((note) => (
              <article class="landing-card landing-example-note">
                <div class="landing-example-note-label">{note.label}</div>
                <p class="type-body-sm">{note.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="privacy-section-block landing-example-shell landing-example-shell-marketing">
      <div class="landing-eyebrow">Example</div>
      <h2>What the review screen looks like</h2>
      <p>
        One screen holds the page preview, suggested redactions, and manual tools so you can check everything before export.
      </p>

      <div class="landing-example-grid">
        <div class="landing-card landing-example-frame">
          <picture>
            <source srcset={`${baseUrl}example.webp`} type="image/webp" />
            <img
              alt="Example of the HDDN redaction review workspace with a PDF preview, highlighted detections, and a review sidebar."
              class="landing-example-image"
              height="1024"
              loading="lazy"
              src={`${baseUrl}example.png`}
              width="1536"
            />
          </picture>
        </div>

        <div class="landing-example-notes" aria-label="Example highlights">
          {notes.map((note) => (
            <article class="landing-card landing-example-note">
              <div class="landing-example-note-label">{note.label}</div>
              <p class="type-body-sm">{note.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
