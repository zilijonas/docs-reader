---
import { Image } from 'astro:assets';
import exampleImage from '../../../assets/example.png';

interface Props {
  variant?: 'landing' | 'marketing';
}

const { variant = 'landing' } = Astro.props;

const notes = [
  {
    label: 'Page preview',
    text: 'See the PDF page and highlighted areas before anything is exported.',
  },
  {
    label: 'Review queue',
    text: 'Check suggested detections one by one and keep only what should be redacted.',
  },
  {
    label: 'Manual control',
    text: 'Add your own redactions when the document needs extra cleanup.',
  },
] as const;

const eyebrowClass =
  'font-mono text-caption leading-4 tracking-eyebrow uppercase text-content-subtle';
const titleClass = 'max-w-measure-landing-section text-display-section tracking-tight-section';
---

{
  variant === 'landing' ? (
    <section class="border-border border-t">
      <div class="layout-shell py-16">
        <div class="grid gap-5 md:grid-cols-(--layout-grid-landing-split) md:items-end">
          <div>
            <div class:list={[eyebrowClass, 'mb-3']}>Example</div>
            <h2 class={titleClass}>
              Review workspace. Clear page view. Final decision stays with you.
            </h2>
          </div>
          <p class="text-content-muted text-body-md leading-copy-relaxed">
            The app shows the page, suggested redactions, and manual tools in one place so you can
            inspect every change before export.
          </p>
        </div>

        <div class="mt-8 grid gap-4 xl:grid-cols-(--layout-grid-landing-example)">
          <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-3 sm:p-4">
            <Image
              alt="Example of the hddn redaction review workspace with a PDF preview, highlighted detections, and a review sidebar."
              class="border-border/70 w-full rounded-2xl border"
              formats={['webp']}
              loading="lazy"
              sizes="(min-width: 1280px) 58vw, (min-width: 768px) calc(100vw - 4rem), calc(100vw - 2rem)"
              src={exampleImage}
              widths={[640, 960, 1280, 1536]}
            />
          </div>

          <div class="grid gap-3" aria-label="Example highlights">
            {notes.map((note) => (
              <article class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-5">
                <div class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                  {note.label}
                </div>
                <p class="text-content-muted leading-copy mt-2 text-sm">{note.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section>
      <div class={eyebrowClass}>Example</div>
      <h2>What the review screen looks like</h2>
      <p>
        One screen holds the page preview, suggested redactions, and manual tools so you can check
        everything before export.
      </p>

      <div class="mt-4 grid gap-4 xl:grid-cols-(--layout-grid-landing-example)">
        <div class="border-border bg-surface-muted rounded-(--radius-panel) border p-3 sm:p-4">
          <Image
            alt="Example of the hddn redaction review workspace with a PDF preview, highlighted detections, and a review sidebar."
            class="border-border/70 w-full rounded-2xl border"
            formats={['webp']}
            loading="lazy"
            sizes="(min-width: 1280px) 58vw, (min-width: 768px) calc(100vw - 4rem), calc(100vw - 2rem)"
            src={exampleImage}
            widths={[640, 960, 1280, 1536]}
          />
        </div>

        <div class="grid gap-3" aria-label="Example highlights">
          {notes.map((note) => (
            <article class="border-border bg-surface-muted rounded-2xl border p-4">
              <div class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                {note.label}
              </div>
              <p class="text-content-muted leading-copy mt-2 text-sm">{note.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
