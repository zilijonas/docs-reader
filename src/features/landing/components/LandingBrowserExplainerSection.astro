---
import { ArrowRight, FileText, Globe, Monitor } from 'lucide-react';
import { browserExplainer } from '../data';

const eyebrowClass =
  'font-mono text-caption leading-4 tracking-eyebrow uppercase text-content-subtle';
const titleClass = 'max-w-measure-landing-section text-display-section tracking-tight-section';
---

<section class="border-border border-t">
  <div class="layout-shell py-16">
    <div class="grid gap-4 lg:grid-cols-(--layout-grid-landing-aside)">
      <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-6 sm:p-7">
        <div class:list={[eyebrowClass, 'mb-3']}>{browserExplainer.eyebrow}</div>
        <h2 class:list={[titleClass, 'mb-5']}>{browserExplainer.title}</h2>
        <div class="grid gap-3">
          {
            browserExplainer.paragraphs.map((paragraph) => (
              <p class="text-content-muted max-w-measure-landing-privacy text-body-md leading-copy-relaxed">
                {paragraph}
              </p>
            ))
          }
        </div>
      </div>

      <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-6 sm:p-7">
        <div
          class="text-content-subtle text-badge tracking-label mb-4 font-mono leading-4 uppercase"
        >
          {browserExplainer.shortTitle}
        </div>
        <div class="flex flex-wrap gap-2">
          {
            browserExplainer.shortPoints.map((point) => (
              <span class="border-border bg-surface-muted text-content-muted rounded-full border px-3 py-1 text-sm">
                {point}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="border-border bg-surface shadow-panel mt-4 rounded-(--radius-panel) border p-6 sm:p-7"
    >
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
          What actually happens
        </span>
        <span
          class="bg-success-soft text-success-ink text-caption tracking-soft inline-flex items-center gap-1.5 rounded-full border border-[color:color-mix(in_oklab,var(--theme-success)_25%,var(--theme-border))] px-2.5 py-1 font-mono"
        >
          browser-side
        </span>
      </div>

      <div
        class="grid gap-3 md:grid-cols-(--layout-grid-explainer-flow)"
        aria-label={browserExplainer.shortTitle}
      >
        <div class="border-border bg-surface-muted rounded-2xl border p-4">
          <span
            class="bg-canvas text-content-subtle mb-2 inline-flex size-8 items-center justify-center rounded-full"
            aria-hidden="true"
          >
            <Globe size={18} strokeWidth={1.6} />
          </span>
          <span class="text-content block text-sm font-medium">hddn loads</span>
          <span class="text-content-muted mt-1 block text-xs"
            >The site loads the tool into your browser.</span
          >
        </div>
        <span class="text-content-subtle hidden self-center md:inline" aria-hidden="true">
          <ArrowRight size={18} strokeWidth={1.5} />
        </span>
        <div class="border-border bg-surface-muted rounded-2xl border p-4">
          <span
            class="bg-canvas text-content-subtle mb-2 inline-flex size-8 items-center justify-center rounded-full"
            aria-hidden="true"
          >
            <Monitor size={18} strokeWidth={1.6} />
          </span>
          <span class="text-content block text-sm font-medium">Your browser works</span>
          <span class="text-content-muted mt-1 block text-xs"
            >Open, review, and prepare the PDF on your device.</span
          >
        </div>
        <span class="text-content-subtle hidden self-center md:inline" aria-hidden="true">
          <ArrowRight size={18} strokeWidth={1.5} />
        </span>
        <div class="border-border bg-surface-muted rounded-2xl border p-4">
          <span
            class="bg-canvas text-content-subtle mb-2 inline-flex size-8 items-center justify-center rounded-full"
            aria-hidden="true"
          >
            <FileText size={18} strokeWidth={1.6} />
          </span>
          <span class="text-content block text-sm font-medium">Your PDF stays put</span>
          <span class="text-content-muted mt-1 block text-xs"
            >The file does not need to be sent anywhere to be edited.</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
