---
import { Shield } from "lucide-react";
import { privacyHighlights, privacySection } from "../data";
---

<section id="privacy" class="landing-section-shell">
  <div class="page-container section-space">
    <div class="landing-privacy-panel">
      <div class="landing-privacy-copy-block">
        <div class="landing-privacy-kicker">
          <span class="landing-privacy-kicker-icon" aria-hidden="true">
            <Shield size={14} strokeWidth={1.7} />
          </span>
          <span class="landing-eyebrow text-inherit">{privacySection.eyebrow}</span>
        </div>
        <h2 class="type-display-section measure-landing-privacy mb-6">
          {privacySection.title}
        </h2>
        <div class="landing-privacy-copy">
          {
            privacySection.paragraphs.map((paragraph) => (
              <p class="type-body measure-landing-privacy">{paragraph}</p>
            ))
          }
          <p class="type-body measure-landing-privacy">{privacySection.supportLine}</p>
        </div>
      </div>

      <div class="landing-privacy-proof">
        <div class="landing-pipeline-head">
          <span class="landing-pipeline-label text-inherit">{privacySection.highlightsTitle}</span>
          <span class="landing-privacy-proof-badge">local review</span>
        </div>
        <ul class="landing-privacy-proof-grid">
          {
            privacyHighlights.map((item, index) => (
              <li class="landing-privacy-proof-card">
                <span class="landing-privacy-proof-index">0{index + 1}</span>
                <span class="landing-privacy-proof-text">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
