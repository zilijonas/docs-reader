---
import { Shield } from "lucide-react";
import { techHighlights } from "../data";
---

<section id="privacy" class="landing-section-shell">
  <div class="page-container section-space">
    <div class="landing-privacy-grid">
      <div>
        <div class="landing-eyebrow mb-3">Privacy by design</div>
        <h2 class="type-display-section measure-landing-privacy mb-6">
          Your document stays in your browser during processing.
        </h2>
        <div class="landing-privacy-copy">
          <p class="type-body measure-landing-privacy">
            There is no app server for document processing, uploads, or storage.
          </p>
          <p class="type-body measure-landing-privacy">
            Text extraction, OCR, detection, review, and export run locally
            using WebAssembly.
          </p>
          <p class="type-body measure-landing-privacy">
            Google Analytics may collect site usage metrics, but document
            contents are not sent there.
          </p>
        </div>
      </div>

      <div class="landing-card landing-tech-shell">
        <div class="landing-pipeline-head">
          <span class="landing-pipeline-label">How it runs</span>
          <span class="status-pill">
            <Shield size={10} strokeWidth={1.5} />
            local only
          </span>
        </div>
        <ul class="landing-tech-list">
          {
            techHighlights.map((item) => (
              <li class="landing-tech-item">{item}</li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
