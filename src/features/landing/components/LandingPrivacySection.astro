---
import { Check, Lock, Shield } from 'lucide-react';
import { pipelineSteps, privacyBullets } from '../data';
---

<section id="privacy" class="landing-section-shell">
  <div class="page-container section-space">
    <div class="landing-privacy-grid">
      <div>
        <div class="landing-eyebrow mb-3">Privacy, structurally</div>
        <h2 class="type-display-section mb-6 max-w-[480px]">
          Your document never leaves this tab.
        </h2>
        <p class="type-body max-w-[480px]">
          There is no backend to breach. PDF parsing, OCR, detection, and redaction all run as WebAssembly inside your browser. The moment you close the tab, the document is gone.
        </p>
        <div class="landing-bullet-list">
          {privacyBullets.map((bullet) => (
            <div class="landing-bullet-row">
              <div class="landing-bullet-icon">
                <Check size={12} strokeWidth={1.5} />
              </div>
              <div>
                <div class="landing-bullet-title">{bullet.title}</div>
                <div class="landing-bullet-copy">{bullet.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="landing-card landing-pipeline-shell">
        <div class="landing-pipeline-head">
          <span class="landing-pipeline-label">Where your document goes</span>
          <span class="status-pill">
            <Shield size={10} strokeWidth={1.5} />
            local only
          </span>
        </div>
        <div class="landing-pipeline-list">
          {pipelineSteps.map((step) => (
            <div class="landing-pipeline-row">
              <div class="landing-pipeline-dot" data-filled={step.filled ? 'true' : 'false'}></div>
              <div class="landing-pipeline-copy">
                <div class="landing-pipeline-title">{step.title}</div>
                <div class="landing-pipeline-note">{step.description}</div>
              </div>
              <Lock class="text-content-subtle" size={12} strokeWidth={1.5} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
