---
import { Shield } from 'lucide-react';
import { privacyHighlights, privacySection } from '../data';

const eyebrowClass = 'ui-eyebrow-pill';
const titleClass = 'max-w-measure-landing-privacy text-display-section tracking-tight-section';
---

<section id="privacy" class="border-border border-t">
  <div class="layout-shell py-16">
    <div class="grid gap-4 lg:grid-cols-(--layout-grid-landing-aside)">
      <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-6 sm:p-7">
        <span class:list={[eyebrowClass, 'mb-4']}
          ><Shield size={14} strokeWidth={1.7} /> {privacySection.eyebrow}</span
        >
        <h2 class:list={[titleClass, 'mb-5']}>{privacySection.title}</h2>
        <div class="grid gap-3">
          {
            privacySection.paragraphs.map((paragraph) => (
              <p class="text-content-muted max-w-measure-landing-privacy text-body-md leading-copy-relaxed">
                {paragraph}
              </p>
            ))
          }
          <p
            class="text-content-muted max-w-measure-landing-privacy text-body-md leading-copy-relaxed"
          >
            {privacySection.supportLine}
          </p>
        </div>
      </div>

      <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-6 sm:p-7">
        <div class="mb-4 flex items-center justify-between gap-3">
          <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
            {privacySection.highlightsTitle}
          </span>
          <span
            class="border-success/30 bg-success-soft text-success-ink text-caption tracking-soft rounded-full border px-2.5 py-1 font-mono uppercase"
          >
            local review
          </span>
        </div>
        <ul class="grid gap-2 sm:grid-cols-2">
          {
            privacyHighlights.map((item, index) => (
              <li class="border-border bg-surface-muted grid gap-2 rounded-2xl border p-4">
                <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                  0{index + 1}
                </span>
                <span class="text-content leading-copy text-sm">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
