---
import { Bot, Check, Files, Send, Shield } from 'lucide-react';
import { useCasesSection } from '../data';

const eyebrowClass = 'ui-eyebrow-pill';
const titleClass = 'max-w-measure-landing-section text-display-section tracking-tight-section';
---

<section class="border-border border-t">
  <div class="layout-shell py-16">
    <div class="mb-8">
      <div class:list={[eyebrowClass, 'mb-3']}>
        <Check size={14} strokeWidth={1.7} />{useCasesSection.eyebrow}
      </div>
      <h2 class={titleClass}>{useCasesSection.title}</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {
        useCasesSection.items.map((item) => (
          <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-5">
            <div class="mb-3 flex items-center gap-3">
              <span
                class="bg-surface-muted text-content-subtle inline-flex size-8 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                {item.icon === 'send' ? (
                  <Send size={18} strokeWidth={1.6} />
                ) : item.icon === 'bot' ? (
                  <Bot size={18} strokeWidth={1.6} />
                ) : item.icon === 'files' ? (
                  <Files size={18} strokeWidth={1.6} />
                ) : (
                  <Shield size={18} strokeWidth={1.6} />
                )}
              </span>
              <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                {item.label}
              </span>
            </div>
            <h3 class="text-title-card tracking-tight-card">{item.title}</h3>
            <p class="text-content-muted leading-copy mt-2 text-sm">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
