---
import { whySection } from '../data';

const eyebrowClass =
  'font-mono text-caption leading-4 tracking-eyebrow uppercase text-content-subtle';
const titleClass = 'max-w-measure-landing-section text-display-section tracking-tight-section';
---

<section class="border-border border-t">
  <div class="layout-shell py-16">
    <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-6 sm:p-8">
      <div class="grid gap-6 md:grid-cols-(--layout-grid-landing-aside)">
        <div>
          <div class:list={[eyebrowClass, 'mb-3']}>{whySection.eyebrow}</div>
          <h2 class={titleClass}>{whySection.title}</h2>
          <p class="text-content-muted text-body-md leading-copy-relaxed mt-4">
            {whySection.intro}
          </p>
        </div>

        <ul class="grid content-start gap-2" aria-label="Why people use hddn">
          {
            whySection.items.map((item) => (
              <li class="border-border bg-surface-muted flex items-center gap-3 rounded-2xl border px-3 py-2.5">
                <span class="bg-success size-2 rounded-full" aria-hidden="true" />
                <span class="text-content leading-copy text-sm">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
