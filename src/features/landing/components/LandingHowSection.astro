---
import { Download, Eye, Search, Upload } from 'lucide-react';
import { howSection, howSteps } from '../data';
---

<section id="how" class="landing-section-shell">
  <div class="page-container section-space">
    <div class="landing-section-head">
      <div>
        <div class="landing-eyebrow mb-3">{howSection.eyebrow}</div>
        <h2 class="type-display-section measure-landing-section">{howSection.title}</h2>
      </div>
      <p class="landing-section-copy type-body">{howSection.intro}</p>
    </div>

    <div class="landing-feature-grid">
      {howSteps.map((step) => (
        <div class="landing-card landing-feature-card">
          <div class="landing-feature-card-head">
            <span class="type-data">{step.number}</span>
            {step.icon === 'upload' ? (
              <Upload className="text-content-muted" size={18} strokeWidth={1.5} />
            ) : step.icon === 'search' ? (
              <Search className="text-content-muted" size={18} strokeWidth={1.5} />
            ) : step.icon === 'review' ? (
              <Eye className="text-content-muted" size={18} strokeWidth={1.5} />
            ) : (
              <Download className="text-content-muted" size={18} strokeWidth={1.5} />
            )}
          </div>
          <h3 class="type-display-card">{step.title}</h3>
          <p class="type-body-sm">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
