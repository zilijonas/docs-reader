---
import { Download, Eye, Search, Upload } from 'lucide-react';
import { howSection, howSteps } from '../data';

const eyebrowClass = 'ui-eyebrow-pill';
const titleClass = 'max-w-measure-landing-section text-display-section tracking-tight-section';
---

<section id="how" class="border-border border-t">
  <div class="layout-shell py-16">
    <div class="grid gap-5 md:grid-cols-(--layout-grid-landing-split) md:items-end">
      <div>
        <div class:list={[eyebrowClass, 'mb-3']}>{howSection.eyebrow}</div>
        <h2 class={titleClass}>{howSection.title}</h2>
      </div>
      <p class="text-content-muted text-body-md leading-copy-relaxed">{howSection.intro}</p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        howSteps.map((step) => (
          <div class="border-border bg-surface shadow-panel rounded-(--radius-panel) border p-5">
            <div class="mb-3 flex items-center justify-between gap-3">
              <span class="text-content-subtle text-badge tracking-label font-mono leading-4 uppercase">
                {step.number}
              </span>
              {step.icon === 'upload' ? (
                <Upload className="text-content-muted" size={18} strokeWidth={1.5} />
              ) : step.icon === 'search' ? (
                <Search className="text-content-muted" size={18} strokeWidth={1.5} />
              ) : step.icon === 'review' ? (
                <Eye className="text-content-muted" size={18} strokeWidth={1.5} />
              ) : (
                <Download className="text-content-muted" size={18} strokeWidth={1.5} />
              )}
            </div>
            <h3 class="text-title-card tracking-tight-card">{step.title}</h3>
            <p class="text-content-muted leading-copy mt-2 text-sm">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
