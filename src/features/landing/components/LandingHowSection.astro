---
import { Download, Eye, Upload } from 'lucide-react';
import { howSteps } from '../data';
---

<section id="how" class="landing-section-shell">
  <div class="page-container section-space">
    <div class="landing-section-head">
      <div>
        <div class="landing-eyebrow mb-3">How it works</div>
        <h2 class="type-display-section max-w-[600px]">Assistive detection. You stay in control.</h2>
      </div>
      <p class="landing-section-copy type-body">Review stays central from upload to export.</p>
    </div>

    <div class="landing-feature-grid surface-card-grid">
      {howSteps.map((step) => (
        <div class="landing-feature-card surface-card-segment">
          <div class="landing-feature-card-head">
            <span class="type-data">{step.number}</span>
            {step.icon === 'upload' ? (
              <Upload class="text-content-muted" size={18} strokeWidth={1.5} />
            ) : step.icon === 'review' ? (
              <Eye class="text-content-muted" size={18} strokeWidth={1.5} />
            ) : (
              <Download class="text-content-muted" size={18} strokeWidth={1.5} />
            )}
          </div>
          <h3 class="type-display-card">{step.title}</h3>
          <p class="type-body-sm">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
