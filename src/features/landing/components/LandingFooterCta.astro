---
import { ArrowRight } from 'lucide-react';
import { BrandLogo } from '../../../components/BrandLogo';
import { Button } from '../../../components/ui/Button';
import { footerCta, getLandingFooterLinks } from '../data';
interface Props {
  appUrl: string;
  baseUrl: string;
}

const { appUrl, baseUrl } = Astro.props;
const footerLinks = getLandingFooterLinks(baseUrl);
const footerLinkClass =
  'rounded-full py-1.5 text-sm text-content-muted transition-colors duration-200 hover:text-content';
---

<footer class="border-border bg-canvas/92 border-t backdrop-blur-(--blur-app-header)">
  <div class="layout-shell py-6 sm:py-7">
    <div class="grid gap-5 lg:grid-cols-[auto_1fr_auto] lg:items-center lg:gap-6">
      <a href={baseUrl} class="flex min-w-0 items-center gap-3">
        <BrandLogo
          className="text-content block h-auto w-[5rem] max-[900px]:w-[4.5rem] max-[640px]:w-[3.75rem]"
          title="hddn"
        />
        <span
          class="text-content-subtle text-badge tracking-label inline font-mono leading-4 uppercase"
        >
          Hide what matters.
        </span>
      </a>

      <nav aria-label="Footer information links">
        <ul class="flex flex-wrap items-center gap-4 lg:justify-center">
          {
            footerLinks.map((link) => (
              <li>
                <a class={footerLinkClass} href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex flex-col gap-2 lg:items-end">
        <Button className="w-full sm:w-auto" href={appUrl} size="lg">
          <span>{footerCta.buttonLabel}</span>
          <ArrowRight size={16} strokeWidth={1.5} />
        </Button>
        <p class="text-content-subtle leading-tight-copy text-xs">{footerCta.trustLine}</p>
      </div>
    </div>
  </div>
</footer>
