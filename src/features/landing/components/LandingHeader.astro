---
import { Pencil } from 'lucide-react';
import { BrandLogo } from '../../../components/BrandLogo';
import { Button } from '../../../components/ui/Button';
import { landingHero, getLandingMobileLinks, getLandingNavLinks } from '../data';
import { LandingMobileNav } from './LandingMobileNav';

interface Props {
  appUrl: string;
  baseUrl: string;
}

const { appUrl, baseUrl } = Astro.props;
const navLinks = getLandingNavLinks(baseUrl);
const mobileLinks = getLandingMobileLinks(baseUrl, appUrl);
const navLinkClass =
  'rounded-full px-3 py-1.5 text-sm text-content-muted transition-colors duration-200 hover:text-content';
---

<header
  class="z-overlay border-border bg-canvas/92 sticky top-0 border-b backdrop-blur-(--blur-app-header)"
>
  <div class="layout-shell">
    <div class="flex h-(--landing-header-height) items-center justify-between gap-4">
      <a href={baseUrl} class="flex min-w-0 items-center gap-3">
        <BrandLogo
          className="text-content block h-auto w-[5rem] max-[900px]:w-[4.5rem] max-[640px]:w-[3.75rem]"
          title="hddn"
        />
        <span
          class="text-content-subtle text-badge tracking-label hidden font-mono leading-4 uppercase sm:inline"
        >
          Hide what matters.
        </span>
      </a>

      <div class="flex items-center gap-2">
        <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
          {
            navLinks.map((link) => (
              <a class={navLinkClass} href={link.href}>
                {link.label}
              </a>
            ))
          }
        </nav>

        <Button className="hidden sm:inline-flex" href={appUrl}>
          <span>{landingHero.primaryCta}</span>
          <Pencil size={16} strokeWidth={1.9} />
        </Button>

        <Button aria-label={landingHero.primaryCta} className="sm:hidden" href={appUrl}>
          <Pencil size={16} strokeWidth={1.9} />
        </Button>

        <LandingMobileNav client:idle links={mobileLinks} />
      </div>
    </div>
  </div>
</header>
