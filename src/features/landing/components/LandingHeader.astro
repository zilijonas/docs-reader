---
import { Pencil } from "lucide-react";
import { BrandLogo } from "../../../components/BrandLogo";
import {
  landingHero,
  getLandingMobileLinks,
  getLandingNavLinks,
} from "../data";
import { LandingMobileNav } from "./LandingMobileNav";

interface Props {
  appUrl: string;
  baseUrl: string;
}

const { appUrl, baseUrl } = Astro.props;
const navLinks = getLandingNavLinks(baseUrl);
const mobileLinks = getLandingMobileLinks(baseUrl, appUrl);
---

<header class="landing-header">
  <div class="page-container landing-header-shell">
    <a href={baseUrl} class="landing-brand">
      <BrandLogo className="landing-brand-logo" title="hddn" />
      <span class="landing-brand-meta type-data">Hide what matters.</span>
    </a>

    <div class="landing-nav">
      {
        navLinks.map((link) => (
          <a class="landing-nav-link" href={link.href}>
            {link.label}
          </a>
        ))
      }
      <div class="landing-header-actions">
        <a
          class="landing-button landing-header-cta-text px-2.5 py-1.5 text-xs whitespace-nowrap"
          href={appUrl}
        >
          <span>{landingHero.primaryCta}</span>
          <Pencil size={16} strokeWidth={1.9} />
        </a>
        <a
          aria-label={landingHero.primaryCta}
          class="landing-button landing-header-cta-mobile-icon"
          href={appUrl}
        >
          <Pencil size={16} strokeWidth={1.9} />
        </a>
        <LandingMobileNav client:idle links={mobileLinks} />
      </div>
    </div>
  </div>
</header>
