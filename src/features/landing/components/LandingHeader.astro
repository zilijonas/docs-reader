---
import { ArrowRight, Shield } from 'lucide-react';
import { landingNavLinks } from '../data';

interface Props {
  appUrl: string;
}

const { appUrl } = Astro.props;
---

<header class="landing-header">
  <div class="page-container landing-header-shell">
    <div class="landing-brand">
      <Shield size={20} strokeWidth={1.75} />
      <span class="landing-brand-title">Obscura</span>
      <span class="landing-brand-meta type-data">
        / docs-reader
      </span>
    </div>

    <div class="landing-nav">
      {landingNavLinks.map((link) => (
        <a class="landing-nav-link" href={link.href}>{link.label}</a>
      ))}
      <a class="landing-button px-2.5 py-1.5 text-xs" href={appUrl}>
        <span>Open the app</span>
        <ArrowRight size={14} strokeWidth={1.5} />
      </a>
    </div>
  </div>
</header>
