---
import {
  ArrowRight,
  CloudOff,
  Eye,
  FileLock,
  FilePen,
  Monitor,
  MonitorSmartphone,
  Pencil,
  Shield,
  ShieldCheck,
} from 'lucide-react';
import { Button } from '../../../components/ui/Button';
import { StatusPill } from '../../../components/ui/StatusPill';
import { heroTrustBadges, landingHero } from '../data';
import LandingHeroDiagram from './LandingHeroDiagram.astro';

interface Props {
  appUrl: string;
  howItWorksUrl: string;
}

const { appUrl, howItWorksUrl } = Astro.props;
---

<section
  class="border-border relative flex min-h-[calc(100svh-var(--landing-header-height))] flex-col items-center justify-center overflow-hidden border-b bg-[linear-gradient(180deg,color-mix(in_oklab,var(--theme-canvas)_94%,white)_0%,var(--theme-canvas)_100%)] py-4 sm:pt-12 md:pb-18"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -right-[120%] hidden justify-center md:flex lg:-right-[62%]"
  >
    <div class="fade-in fade-in-delay-1 max-w-layout-diagram w-full opacity-70">
      <LandingHeroDiagram />
    </div>
  </div>

  <div
    class="layout-shell z-raised relative grid gap-8 md:grid-cols-(--layout-grid-landing-main) md:items-end"
  >
    <div
      class="border-border bg-surface/92 shadow-float rounded-(--radius-panel) border p-6 backdrop-blur-sm sm:p-8"
    >
      <div class="grid gap-5">
        <div class="flex items-center gap-2">
          <StatusPill className="fade-in w-fit flex-shrink-0" size="sm" status="trust">
            <ShieldCheck size={14} strokeWidth={1.7} />
            <span>{landingHero.statusPill}</span>
          </StatusPill>
          <StatusPill className="fade-in w-fit flex-shrink-0" size="sm" status="trust">
            <MonitorSmartphone size={14} strokeWidth={1.7} />
            <span>{landingHero.statusDetail}</span>
          </StatusPill>
        </div>

        <h1 class="fade-in text-display-hero tracking-tight-hero text-balance">
          {landingHero.headlineLead}
          <em class="text-brand">{landingHero.headlineAccent}</em><br />
          {landingHero.headlineTrail}
        </h1>

        <p
          class="fade-in fade-in-delay-1 text-content-muted max-w-measure-landing-hero leading-reading text-lg text-pretty max-sm:text-sm"
        >
          {landingHero.subtext}
        </p>

        <ul class="mt-1 grid grid-cols-2 gap-1.5 sm:hidden" aria-label="Key trust points">
          {
            heroTrustBadges.map((badge) => (
              <li
                class="border-border bg-surface-muted flex min-w-0 items-center gap-2 rounded-xl border px-2 py-1.5"
                aria-label={`${badge.label}. ${badge.note}`}
              >
                <span
                  class="bg-canvas text-content-subtle inline-flex size-7 shrink-0 items-center justify-center rounded-full"
                  aria-hidden="true"
                >
                  {badge.icon === 'cloudOff' ? (
                    <CloudOff size={14} strokeWidth={1.6} />
                  ) : badge.icon === 'monitor' ? (
                    <Monitor size={14} strokeWidth={1.6} />
                  ) : badge.icon === 'eye' ? (
                    <Eye size={14} strokeWidth={1.6} />
                  ) : (
                    <FileLock size={14} strokeWidth={1.6} />
                  )}
                </span>
                <span class="grid min-w-0">
                  <span class="text-content text-control leading-none font-medium">
                    {badge.mobileLabel}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>

        <div class="fade-in fade-in-delay-3 mt-1 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <Button className="w-full sm:w-auto" href={appUrl} size="lg">
            <FilePen size={16} strokeWidth={1.5} />
            <span>{landingHero.primaryCta}</span>
            <ArrowRight size={16} strokeWidth={1.5} />
          </Button>
          <Button className="w-full sm:w-auto" href={howItWorksUrl} size="lg" variant="secondary">
            <Eye size={16} strokeWidth={1.5} />
            <span>{landingHero.secondaryCta}</span>
          </Button>
        </div>

        <ul
          class="fade-in fade-in-delay-2 text-content-subtle leading-tight-copy flex flex-wrap gap-4 text-xs max-sm:hidden"
        >
          {landingHero.quickPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </div>

    <div
      class="fade-in fade-in-delay-3 border-border bg-surface/95 shadow-panel hidden rounded-(--radius-panel) border p-5 backdrop-blur-sm sm:block"
    >
      <ul class="grid gap-3" aria-label="Key trust points">
        {
          heroTrustBadges.map((badge) => (
            <li class="flex items-start gap-3" aria-label={`${badge.label}. ${badge.note}`}>
              <span
                class="bg-surface-muted text-content-subtle inline-flex size-10 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                {badge.icon === 'cloudOff' ? (
                  <CloudOff size={20} strokeWidth={1.6} />
                ) : badge.icon === 'monitor' ? (
                  <Monitor size={20} strokeWidth={1.6} />
                ) : badge.icon === 'eye' ? (
                  <Eye size={20} strokeWidth={1.6} />
                ) : (
                  <FileLock size={20} strokeWidth={1.6} />
                )}
              </span>
              <span class="grid min-w-0 gap-0.5">
                <span class="text-content text-sm font-medium">{badge.label}</span>
                <span class="text-content-subtle text-xs">{badge.note}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
