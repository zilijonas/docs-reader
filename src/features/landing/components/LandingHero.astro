---
import { CloudOff, Eye, Monitor, Pencil, Shield } from "lucide-react";
import { heroTrustBadges, landingHero } from "../data";
import LandingHeroDiagram from "./LandingHeroDiagram.astro";

interface Props {
  appUrl: string;
  howItWorksUrl: string;
}

const { appUrl, howItWorksUrl } = Astro.props;
---

<section class="landing-hero">
  <div aria-hidden="true" class="landing-hero-visual">
    <div class="fade-in fade-in-delay-1">
      <LandingHeroDiagram />
    </div>
  </div>
  <div class="page-container landing-hero-inner">
    <div class="landing-hero-panel">
      <div class="landing-hero-content">
        <span class="landing-hero-status fade-in">
          <span class="landing-hero-status-dot" aria-hidden="true"></span>
          <span>{landingHero.statusPill}</span>
          <span class="landing-hero-status-dot" aria-hidden="true"></span>
          <span>{landingHero.statusDetail}</span>
        </span>
        <h1 class="type-display-hero fade-in">
          {landingHero.headlineLead}<br /> Redact <em class="italic-accent">
            {landingHero.headlineAccent}
          </em>

          {landingHero.headlineTrail}
        </h1>
        <p class="landing-hero-copy type-body-lg fade-in fade-in-delay-1">
          {landingHero.subtext}
        </p>
        <ul
          class="landing-trust-badges-compact mt-6"
          aria-label="Key trust points"
        >
          {
            heroTrustBadges.map((badge) => (
              <li
                class="landing-trust-badge"
                aria-label={`${badge.label}. ${badge.note}`}
              >
                <span class="landing-trust-badge-icon" aria-hidden="true">
                  {badge.icon === "cloudOff" ? (
                    <CloudOff size={16} strokeWidth={1.6} />
                  ) : badge.icon === "monitor" ? (
                    <Monitor size={16} strokeWidth={1.6} />
                  ) : badge.icon === "eye" ? (
                    <Eye size={16} strokeWidth={1.6} />
                  ) : (
                    <Shield size={16} strokeWidth={1.6} />
                  )}
                </span>
                <span class="landing-trust-badge-copy">
                  <span class="landing-trust-badge-title">
                    <span class="landing-trust-badge-title-desktop">
                      {badge.label}
                    </span>
                    <span class="landing-trust-badge-title-mobile">
                      {badge.mobileLabel}
                    </span>
                  </span>
                  <span class="landing-trust-badge-note">{badge.note}</span>
                </span>
              </li>
            ))
          }
        </ul>
        <div class="landing-hero-actions fade-in fade-in-delay-3 mt-6">
          <a class="landing-button" href={appUrl}>
            <span>{landingHero.primaryCta}</span>
            <Pencil size={16} strokeWidth={1.5} />
          </a>
          <a class="landing-button-secondary" href={howItWorksUrl}>
            <Eye size={16} strokeWidth={1.5} />
            <span>{landingHero.secondaryCta}</span>
          </a>
        </div>
        <ul class="landing-hero-points type-caption fade-in fade-in-delay-2">
          {landingHero.quickPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>
    </div>
    <div class="landing-trust-strip fade-in fade-in-delay-3">
      <ul class="landing-trust-badges" aria-label="Key trust points">
        {
          heroTrustBadges.map((badge) => (
            <li
              class="landing-trust-badge"
              aria-label={`${badge.label}. ${badge.note}`}
            >
              <span class="landing-trust-badge-icon" aria-hidden="true">
                {badge.icon === "cloudOff" ? (
                  <CloudOff size={24} strokeWidth={1.6} />
                ) : badge.icon === "monitor" ? (
                  <Monitor size={24} strokeWidth={1.6} />
                ) : badge.icon === "eye" ? (
                  <Eye size={24} strokeWidth={1.6} />
                ) : (
                  <Shield size={24} strokeWidth={1.6} />
                )}
              </span>
              <span class="landing-trust-badge-copy">
                <span class="landing-trust-badge-title">
                  <span class="landing-trust-badge-title-desktop">
                    {badge.label}
                  </span>
                  <span class="landing-trust-badge-title-mobile">
                    {badge.mobileLabel}
                  </span>
                </span>
                <span class="landing-trust-badge-note">{badge.note}</span>
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
