---
import { ArrowRight, Eye } from 'lucide-react';
import LandingHeroDiagram from "./LandingHeroDiagram.astro";

interface Props {
  appUrl: string;
}

const { appUrl } = Astro.props;
---

<section class="page-container landing-hero">
  <div class="landing-hero-meta">
    <span class="landing-hero-spot"></span>
    <span class="landing-eyebrow">100% local — no uploads, ever</span>
  </div>
  <h1 class="type-display-hero max-w-[940px]">
    Redact a PDF<br />without ever sending it<br /><span class="italic text-content-muted">anywhere.</span>
  </h1>
  <p class="landing-hero-copy type-body-lg">
    Drop in a document. We detect sensitive spans, you approve each one, and a
    clean redacted PDF is produced — entirely inside your browser.
  </p>
  <div class="landing-hero-actions">
    <a class="landing-button" href={appUrl}>
      <span>Try it now</span>
      <ArrowRight size={16} strokeWidth={1.5} />
    </a>
    <a class="landing-button-secondary" href="#how">
      <Eye size={16} strokeWidth={1.5} />
      <span>See how it works</span>
    </a>
  </div>

  <LandingHeroDiagram />
</section>
