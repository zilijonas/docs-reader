---
import "../styles/global.css";
import { AnalyticsConsentController } from "../features/consent/components/AnalyticsConsentController";
import {
  ANALYTICS_CONSENT_COOKIE_NAME,
  ANALYTICS_CONSENT_COOKIE_VERSION,
} from "../features/consent/cookie";
import { ANALYTICS } from "../lib/app-config";

interface Props {
  title?: string;
  description?: string;
  viewportContent?: string;
}

const {
  title = "HDDN - Hide what matters.",
  description = "Redact PDFs locally in your browser. Document contents stay on-device during processing.",
  viewportContent = "width=device-width",
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site ?? new URL("https://example.github.io");
const pageUrl = new URL(Astro.url.pathname, siteUrl);
const ogImageWebpUrl = new URL(`${baseUrl}og-image.webp`, siteUrl);
const ogImageUrl = new URL(`${baseUrl}og-image.png`, siteUrl);
const enableAnalytics = ANALYTICS.enabled;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content={viewportContent} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageWebpUrl} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="HDDN document redactor preview image" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <AnalyticsConsentController client:idle enabled={enableAnalytics} measurementId={ANALYTICS.measurementId} />
  </body>
</html>
