---
import "../styles/global.css";
import { AnalyticsConsentController } from "../components/analytics/AnalyticsConsentController";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "HDDN - Hide what matters.",
  description = "Redact PDFs locally in your browser. Document contents stay on-device during processing.",
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const googleAnalyticsId = "G-X1ZEX4LY01";
const enableAnalytics = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <AnalyticsConsentController
      client:load
      enabled={enableAnalytics}
      measurementId={googleAnalyticsId}
    />
  </body>
</html>
