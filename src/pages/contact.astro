---
import MarketingPageShell from "../features/landing/components/MarketingPageShell.astro";
import { SEO } from "../lib/seo";

const baseUrl = import.meta.env.BASE_URL;
---

<MarketingPageShell
  baseUrl={baseUrl}
  eyebrow="Contact"
  intro="Questions, bug reports, privacy concerns, or feedback about the PDF redaction tool. Reach out here."
  pageTitle="Contact"
  seo={SEO.contact}
>
  <section class="privacy-section-block contact-page-card">
    <p>hddn is created by:</p>
    <p><strong>Linas Jonas Zilinskas</strong></p>
    <p>If you have questions, feedback, or issues, you can reach out at:</p>
    <p><a href="mailto:lijonas.it@gmail.com">lijonas.it@gmail.com</a></p>
  </section>
</MarketingPageShell>
