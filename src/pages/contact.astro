  description="Contact hddn with questions, feedback, or issues."
  eyebrow="Contact"
  intro="Questions, feedback, or issues. Reach out here."
  pageTitle="Contact"
  title="Contact | hddn"
>
  <section class="privacy-section-block contact-page-card">
    <p>hddn is created by:</p>
    <p><strong>Linas Jonas Zilinskas</strong></p>
    <p>If you have questions, feedback, or issues, you can reach out at:</p>
    <p><a href="mailto:lijonas.it@gmail.com">lijonas.it@gmail.com</a></p>
  </section>
</MarketingPageShell>
