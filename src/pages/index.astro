    <!-- How it works -->
    <section
      id="how"
      class="landing-section"
      style="max-width:1160px;margin:0 auto;padding:72px 40px;border-top:1px solid var(--line);"
    >
      <div
        style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:48px;flex-wrap:wrap;gap:24px;"
      >
        <div>
          <div
            style="font-family:var(--mono);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink-3);margin-bottom:12px;"
          >
            Three steps — nothing hidden
          </div>
          <h2
            class="landing-how-title"
            style="font-family:var(--serif);font-weight:400;font-size:48px;letter-spacing:-0.02em;margin:0;max-width:600px;line-height:1.05;"
          >
            Review-first, <span style="font-style:italic;">not</span> one-click magic.
          </h2>
        </div>
        <p
          style="max-width:360px;font-size:15px;line-height:1.6;color:var(--ink-2);"
        >
          Detection is assistive. You stay in control of every decision, and
          nothing is committed until you ask for the export.
        </p>
      </div>

      <div
        class="landing-feature-grid"
        style="display:grid;grid-template-columns:repeat(3, 1fr);gap:0;border:1px solid var(--line);border-radius:4px;"
      >
        <div
          class="landing-feature-card"
          style="padding:32px 28px 34px;border-right:1px solid var(--line);display:flex;flex-direction:column;gap:16px;min-height:240px;"
        >
          <div
            style="display:flex;align-items:center;justify-content:space-between;"
          >
            <span
              style="font-family:var(--mono);font-size:11px;letter-spacing:0.14em;color:var(--ink-3);"
