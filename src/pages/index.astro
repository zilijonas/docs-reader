---
import Layout from "../layouts/Layout.astro";

const baseUrl = import.meta.env.BASE_URL;
const appUrl = `${baseUrl}app`;
---

<Layout
  title="Obscura — Document Redactor"
  description="Privacy-first PDF redaction with a worker-based in-browser pipeline for searchable and scanned documents."
>
  <div class="landing-shell" style="background: var(--paper); color: var(--ink); min-height: 100vh;">
    <!-- Top bar -->
    <header
      class="landing-header"
      style="display:flex;align-items:center;justify-content:space-between;padding:22px 40px;border-bottom:1px solid var(--line);position:sticky;top:0;background:color-mix(in oklab, var(--paper) 92%, transparent);backdrop-filter:blur(12px);z-index:10;"
    >
      <div class="landing-header-inner">
        <div style="display:flex;align-items:center;gap:10px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <rect
              x="3"
              y="3"
              width="18"
              height="18"
              rx="3"
              stroke="currentColor"
              stroke-width="1.5"></rect>
            <rect x="7" y="10" width="10" height="2.2" fill="currentColor"></rect>
            <rect x="7" y="14" width="6" height="2.2" fill="currentColor"></rect>
          </svg>
          <span
            style="font-family:var(--serif);font-size:17px;letter-spacing:-0.01em;"
            >Obscura</span
          >
          <span
            style="font-family:var(--mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3);margin-left:6px;"
            >/ docs-reader</span
          >
        </div>
        <div class="landing-nav" style="display:flex;align-items:center;gap:20px;">
          <a
            style="font-size:13px;color:var(--ink-2);text-decoration:none;"
            href="#how">How it works</a
          >
          <a
            style="font-size:13px;color:var(--ink-2);text-decoration:none;"
            href="#privacy">Privacy</a
          >
          <a
            style="font-size:13px;color:var(--ink-2);text-decoration:none;"
            href="#limits">Limits</a
          >
          <a
            href={appUrl}
            style="display:inline-flex;align-items:center;gap:8px;padding:6px 10px;font-size:12px;font-weight:500;border-radius:8px;background:var(--ink);color:var(--paper);border:1px solid var(--ink);text-decoration:none;"
          >
            <span>Open the app</span>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="landing-section landing-hero" style="max-width:1160px;margin:0 auto;padding:88px 40px 60px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:28px;">
        <span
          style="width:8px;height:8px;border-radius:4px;background:var(--safe);"
        ></span>
        <span
          style="font-family:var(--mono);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink-3);"
          >100% local — no uploads, ever</span
        >
      </div>
      <h1
        class="landing-hero-title"
        style="font-family:var(--serif);font-weight:400;font-size:clamp(44px, 6.4vw, 92px);line-height:0.98;letter-spacing:-0.025em;margin:0;max-width:940px;text-wrap:balance;"
      >
        Redact a PDF<br />without ever sending it<br /><span
          style="font-style:italic;color:var(--ink-2);">anywhere.</span
        >
      </h1>
      <p
        class="landing-hero-copy"
        style="max-width:620px;margin-top:28px;font-size:18px;line-height:1.55;color:var(--ink-2);font-family:var(--sans);text-wrap:pretty;"
      >
        Drop in a document. We detect sensitive spans, you approve each one, and
        a clean redacted PDF is produced — entirely inside your browser.
      </p>
      <div class="landing-hero-actions" style="display:flex;gap:12px;margin-top:40px;align-items:center;">
        <a
          href={appUrl}
          style="display:inline-flex;align-items:center;gap:10px;padding:13px 20px;font-size:14px;font-weight:500;border-radius:8px;background:var(--ink);color:var(--paper);border:1px solid var(--ink);text-decoration:none;"
        >
          <span>Try it now</span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"></path></svg
          >
        </a>
        <a
          href="#how"
          style="display:inline-flex;align-items:center;gap:10px;padding:13px 20px;font-size:14px;font-weight:500;border-radius:8px;background:transparent;color:var(--ink);border:1px solid transparent;text-decoration:none;"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"
            ></path><circle cx="12" cy="12" r="3"></circle></svg
          >
          <span>See how it works</span>
        </a>
      </div>

      <!-- Animated hero diagram -->
      <div
        class="landing-hero-diagram-card"
        style="margin-top:72px;border-radius:10px;padding:24px 28px 28px;background:linear-gradient(180deg, #FFFFFF 0%, #F4F4F8 100%);border:1px solid var(--line);position:relative;overflow:hidden;"
      >
        <div
          aria-hidden="true"
          style="position:absolute;inset:0;background:radial-gradient(700px 240px at 30% -10%, rgba(108,92,231,0.10), transparent 65%), radial-gradient(500px 200px at 90% 120%, rgba(0, 212, 255, 0.08), transparent 60%);pointer-events:none;"
        >
        </div>
        <svg
          class="landing-hero-diagram"
          viewBox="0 0 1000 540"
          style="width:100%;height:auto;display:block;position:relative;"
        >
          <defs>
            <filter id="heroShadow" x="-5%" y="-5%" width="110%" height="115%">
              <feDropShadow
                dx="0"
                dy="10"
                stdDeviation="14"
                flood-color="#0B0B14"
                flood-opacity="0.10"></feDropShadow>
            </filter>
            <linearGradient id="heroCursor" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#6C5CE7"></stop>
              <stop offset="100%" stop-color="#00D4FF"></stop>
            </linearGradient>
          </defs>

          <!-- Page -->
          <g filter="url(#heroShadow)">
            <rect
              x="120"
              y="44"
              width="760"
              height="460"
              rx="6"
              fill="#FFFFFF"
              stroke="#EDEDF0"></rect>
            <text
              x="148"
              y="92"
              font-family="Space Grotesk, Inter, sans-serif"
              font-size="22"
              font-weight="600"
              fill="#111"
              letter-spacing="-0.01em">Employment Agreement</text
            >
            <text
              x="148"
              y="116"
              font-family="JetBrains Mono, monospace"
              font-size="10"
              letter-spacing="1.8"
              fill="#9CA3AF">CONTRACT · 2026-04-18 · 3 PAGES</text
            >
            <line x1="148" y1="132" x2="852" y2="132" stroke="#EDEDF0"></line>

            <!-- Body rule lines -->
            <rect x="148" y="136" width="132" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="382" y="136" width="374" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="172" width="620" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="208" width="136" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="371" y="208" width="385" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="244" width="580" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="280" width="108" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="372" y="280" width="384" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="316" width="540" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="352" width="116" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="430" y="352" width="326" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="388" width="560" height="6" rx="3" fill="#ECECEF"
            ></rect>
            <rect x="148" y="424" width="610" height="6" rx="3" fill="#ECECEF"
            ></rect>

            <!-- Span 1: Amelia Rowntree (y=140) -->
            <rect
              x="280"
              y="131"
              width="100"
              height="16"
              rx="2"
              fill="rgba(245, 158, 11, 0.28)"
              stroke="#F59E0B"
              stroke-width="1.25"
              stroke-dasharray="3 3"
