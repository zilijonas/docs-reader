            </rect>
            <text
              x="266"
              y="359"
              font-family="Inter, sans-serif"
              font-size="10.5"
              font-weight="500"
              fill="#B45309"
              opacity="1"
            >
              GB82 WEST 1234 5698 7654 32
              <animate
                attributeName="fill"
                values="#111; #111; #B45309; #B45309; transparent; transparent"
                keyTimes="0; 0.5938; 0.6625; 0.7188; 0.7625; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </text>
            <rect x="264" y="347" width="0" height="16" rx="2" fill="#111">
              <animate
                attributeName="width"
                values="0; 0; 166; 166"
                keyTimes="0; 0.7188; 0.7625; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </rect>

            <!-- REDACTED stamp -->
            <g transform="translate(680, 62)" opacity="0">
              <rect
                x="0"
                y="0"
                width="172"
                height="26"
                rx="13"
                fill="#ECFDF5"
                stroke="#10B981"
                stroke-width="1"></rect>
              <circle cx="14" cy="13" r="3.5" fill="#10B981"></circle>
              <text
                x="26"
                y="17"
                font-family="JetBrains Mono, monospace"
                font-size="10"
                font-weight="600"
                letter-spacing="1.4"
                fill="#047857">REDACTED · 4 SPANS</text
              >
              <animate
                attributeName="opacity"
                values="0; 0; 1; 1; 0"
                keyTimes="0; 0.78; 0.82; 0.97; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </g>
          </g>

          <!-- Animated cursor -->
          <path
            id="heroCursorPath"
            d="M 70 110 L 160 134 L 287 138 L 503 138 L 295 210 L 455 210 L 263 282 L 495 282 L 271 354 L 553 354 L 930 464 L 930 464"
            fill="none"
            stroke="none"></path>
          <circle r="16" fill="url(#heroCursor)" opacity="0.32">
            <animateMotion
              dur="8s"
              repeatCount="indefinite"
              keyPoints="0;0.05;0.0688;0.1375;0.2438;0.3125;0.4188;0.4875;0.5938;0.6625;0.8125;1"
              keyTimes="0;0.05;0.0688;0.1375;0.2438;0.3125;0.4188;0.4875;0.5938;0.6625;0.8125;1"
              calcMode="spline"
              keySplines="0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1"
            >
              <mpath href="#heroCursorPath"></mpath>
            </animateMotion>
          </circle>
          <!-- <g>
            <path
              d="M 0 0 L 0 20 L 5 15.5 L 8.5 22.5 L 11 21.3 L 7.5 14.5 L 13 14 Z"
              fill="url(#heroCursor)"
              stroke="#FFFFFF"
              stroke-width="1"
              stroke-linejoin="round"></path>
            <animateMotion
              dur="8s"
              repeatCount="indefinite"
