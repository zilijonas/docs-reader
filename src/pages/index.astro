                keyTimes="0; 0.5938; 0.6625; 0.7188; 0.7625; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </text>
            <rect x="285" y="203" width="0" height="16" rx="2" fill="#111">
              <animate
