              keySplines="0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1;0.42 0 0.2 1"
            >
              <mpath href="#heroCursorPath"></mpath>
            </animateMotion>
          </g> -->

          <!-- Bottom badge -->
          <g transform="translate(379, 512)">
            <rect
