            >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--ink-2)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 16V4M6 10l6-6 6 6"></path><path d="M4 20h16"
              ></path></svg
            >
          </div>
          <h3
            style="font-family:var(--serif);font-weight:400;font-size:26px;letter-spacing:-0.015em;margin:0;"
          >
            Drop a PDF
          </h3>
          <p
            style="font-size:14px;line-height:1.6;color:var(--ink-2);margin:0;"
          >
            Searchable pages stay on the native text lane. Scanned pages
            automatically fall back to OCR.
          </p>
        </div>
        <div
          class="landing-feature-card"
          style="padding:32px 28px 34px;border-right:1px solid var(--line);display:flex;flex-direction:column;gap:16px;min-height:240px;"
        >
          <div
            style="display:flex;align-items:center;justify-content:space-between;"
          >
            <span
              style="font-family:var(--mono);font-size:11px;letter-spacing:0.14em;color:var(--ink-3);"
              >02</span
            >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--ink-2)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12Z"
              ></path><circle cx="12" cy="12" r="3"></circle></svg
            >
          </div>
          <h3
            style="font-family:var(--serif);font-weight:400;font-size:26px;letter-spacing:-0.015em;margin:0;"
          >
            Review detections
          </h3>
          <p
            style="font-size:14px;line-height:1.6;color:var(--ink-2);margin:0;"
          >
            Emails, phones, IBANs, cards, dates, IDs, and custom keywords
            surface as suggestions. Approve what should go.
          </p>
        </div>
        <div
          class="landing-feature-card"
          style="padding:32px 28px 34px;display:flex;flex-direction:column;gap:16px;min-height:240px;"
        >
          <div
            style="display:flex;align-items:center;justify-content:space-between;"
          >
            <span
              style="font-family:var(--mono);font-size:11px;letter-spacing:0.14em;color:var(--ink-3);"
              >03</span
            >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--ink-2)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 4v12M6 10l6 6 6-6"></path><path d="M4 20h16"
              ></path></svg
            >
          </div>
          <h3
            style="font-family:var(--serif);font-weight:400;font-size:26px;letter-spacing:-0.015em;margin:0;"
          >
            Export, redacted
