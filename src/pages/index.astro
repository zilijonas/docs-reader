                keyTimes="0; 0.3688; 0.4125; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </rect>

            <!-- Span 3: amelia@example.com (y=284) -->
            <rect
              x="256"
              y="275"
              width="115"
              height="16"
              rx="2"
              fill="rgba(245, 158, 11, 0.28)"
              stroke="#F59E0B"
              stroke-width="1.25"
              stroke-dasharray="3 3"
              opacity="0"
            >
              <animate
                attributeName="opacity"
                values="0; 0; 1; 1; 0; 0"
                keyTimes="0; 0.4188; 0.4875; 0.5438; 0.5875; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </rect>
            <text
              x="259"
              y="286"
              font-family="Inter, sans-serif"
              font-size="10.5"
              font-weight="500"
              fill="#B45309"
              opacity="1"
            >
              amelia@example.com
              <animate
                attributeName="fill"
                values="#111; #111; #B45309; #B45309; transparent; transparent"
                keyTimes="0; 0.5938; 0.6625; 0.7188; 0.7625; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </text>
            <rect x="256" y="275" width="0" height="16" rx="2" fill="#111">
              <animate
                attributeName="width"
                values="0; 0; 115; 115"
                keyTimes="0; 0.5438; 0.5875; 1"
                dur="8s"
                repeatCount="indefinite"></animate>
            </rect>

            <!-- Span 4: GB82 WEST 1234 5698 7654 32 (y=356) -->
            <rect
              x="264"
              y="347"
              width="166"
              height="16"
              rx="2"
              fill="rgba(245, 158, 11, 0.28)"
              stroke="#F59E0B"
              stroke-width="1.25"
              stroke-dasharray="3 3"
              opacity="1"
            >
              <animate
                attributeName="opacity"
                values="0; 0; 1; 1; 0; 0"
                keyTimes="0; 0.5938; 0.6625; 0.7188; 0.7625; 1"
                dur="8s"
