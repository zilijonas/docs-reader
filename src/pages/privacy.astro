---
import MarketingPageShell from "../features/landing/components/MarketingPageShell.astro";
import { ANALYTICS_CONSENT_COOKIE_NAME } from "../features/consent/cookie";

const baseUrl = import.meta.env.BASE_URL;
---

<MarketingPageShell
  baseUrl={baseUrl}
  description="Read how hddn handles privacy, analytics consent, cookies, and local PDF processing."
  eyebrow="Privacy"
  intro="Your PDF stays on your device. hddn does not upload, store, or send your files anywhere for processing."
  pageTitle="Privacy"
  title="Privacy | hddn"
  updatedAt="April 22, 2026"
>
  <section class="privacy-summary-grid">
    <div class="privacy-summary-card">
      <span class="privacy-summary-label">Files</span>
      <strong>Your PDF stays on your device.</strong>
      <p>
        We do not upload, store, or send your files anywhere for processing.
      </p>
    </div>
    <div class="privacy-summary-card">
      <span class="privacy-summary-label">Analytics</span>
      <strong>Google Analytics is optional.</strong>
      <p>
        It only runs if you accept it, and it is not used to access your
        documents.
      </p>
    </div>
    <div class="privacy-summary-card">
      <span class="privacy-summary-label">Control</span>
      <strong>Review stays in your hands.</strong>
      <p>
        You should always review the document before exporting and sharing it.
      </p>
    </div>
  </section>

  <section class="privacy-section-block">
    <h2>Short version</h2>
    <div class="privacy-checklist">
      <p>Your PDF stays on your device.</p>
      <p>We do not upload, store, or send your files anywhere.</p>
      <p>
        We only use Google Analytics, with your consent, to understand basic
        site usage.
      </p>
    </div>
  </section>

  <section class="privacy-section-block">
    <h2>What we do</h2>
    <p>
      hddn is a tool that runs in your browser. When you use it, your PDF is
      opened and processed directly on your device.
    </p>
    <p>We do not:</p>
    <ul class="privacy-bullet-list">
      <li>upload your files</li>
      <li>store your files</li>
      <li>send your files to any server</li>
      <li>use remote AI services or external APIs to process your files</li>
    </ul>
    <p>
      Any detection used by the app runs locally in your browser on your device.
    </p>
    <p>Everything related to your document stays on your device.</p>
  </section>

  <section class="privacy-section-block">
    <h2>How the tool works</h2>
    <p>
      When you open the site, your browser downloads the code needed to run the
      tool. After that, your browser can open and edit your PDF locally.
    </p>
    <p>This means:</p>
    <ul class="privacy-bullet-list">
      <li>your file does not leave your device</li>
      <li>no one else can access your document through hddn</li>
    </ul>
  </section>

  <section class="privacy-section-block">
    <h2>Analytics</h2>
    <p>We use Google Analytics to understand how the site is used.</p>
    <p>This helps us answer questions like:</p>
    <ul class="privacy-bullet-list">
      <li>how many people use the site</li>
      <li>which pages are visited</li>
    </ul>
    <p>Analytics is only enabled if you accept it.</p>
    <p>We do not use analytics to access or analyze your files.</p>
  </section>

  <section class="privacy-section-block">
    <h2>Cookies</h2>
    <div class="privacy-meta-card">
      <p><strong>Cookie name</strong></p>
      <p class="privacy-code">{ANALYTICS_CONSENT_COOKIE_NAME}</p>
      <p><strong>Stores</strong></p>
      <p>accepted or declined</p>
      <p><strong>Used for</strong></p>
      <p>remembering your analytics preference</p>
    </div>
    <ul class="privacy-bullet-list">
      <li>does not track your activity across sites</li>
      <li>is used only to remember your preference</li>
    </ul>
  </section>

  <section class="privacy-section-block">
    <h2>Data storage</h2>
    <p>We do not store your files in:</p>
    <ul class="privacy-bullet-list">
      <li>localStorage</li>
      <li>IndexedDB</li>
      <li>any database</li>
    </ul>
    <p>
      Your PDF is handled temporarily in memory while you use the tool. Once you
      close the page or export your file, it is no longer kept by the app.
    </p>
  </section>

  <section class="privacy-section-block">
    <h2>Hosting and infrastructure</h2>
    <p>The website is hosted on GitHub Pages and served through Cloudflare.</p>
    <p>These services may process basic technical data such as:</p>
    <ul class="privacy-bullet-list">
      <li>IP address</li>
      <li>request metadata</li>
    </ul>
    <p>This is required to deliver the website.</p>
  </section>

  <section class="privacy-section-block privacy-note-block">
    <h2>Your responsibility</h2>
    <p>
      hddn helps you remove sensitive data, but it does not guarantee that all
      sensitive information will be detected.
    </p>
    <p>
      You should always review the document before exporting and sharing it.
    </p>
  </section>

  <section class="privacy-section-block">
    <h2>Contact</h2>
    <p>If you have questions about privacy, contact:</p>
    <p><a href="mailto:lijonas.it@gmail.com">lijonas.it@gmail.com</a></p>
    <p>Linas Jonas Zilinskas</p>
  </section>
</MarketingPageShell>
