---
import Layout from '../layouts/Layout.astro';
import { AppShell } from '../features/redactor/components/AppShell';
import { SEO } from '../lib/seo';
---

<Layout
  seo={SEO.redact}
  viewportContent="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover"
>
  <main id="main-content">
    <AppShell client:only="react" />
  </main>
</Layout>
