---
import { ArrowLeft, ArrowRight, FileSearch, Home, ShieldCheck } from 'lucide-react';
import { Button } from '../components/ui/Button';
import Layout from '../layouts/Layout.astro';
import LandingFooterCta from '../features/landing/components/LandingFooterCta.astro';
import LandingHeader from '../features/landing/components/LandingHeader.astro';
import { SEO } from '../lib/seo';

const baseUrl = import.meta.env.BASE_URL;
const appUrl = `${baseUrl}redact`;
const helpLinks = [
  { href: `${baseUrl}faq`, label: 'Read the FAQ' },
  { href: `${baseUrl}privacy`, label: 'Review privacy details' },
  { href: `${baseUrl}contact`, label: 'Get in touch' },
];
---

<Layout seo={SEO.notFound}>
  <div
    class="flex min-h-screen min-h-svh flex-col bg-[radial-gradient(circle_at_top_left,rgb(217_119_6_/_0.08),transparent_24rem),radial-gradient(circle_at_top_right,rgb(17_17_17_/_0.05),transparent_30rem),linear-gradient(180deg,color-mix(in_oklab,var(--theme-canvas)_94%,white)_0%,var(--theme-canvas)_100%)]"
  >
    <LandingHeader appUrl={appUrl} baseUrl={baseUrl} />

    <main class="layout-shell grid flex-1 items-center py-8 sm:py-12">
      <section
        class="border-border relative isolate grid gap-6 overflow-hidden rounded-(--radius-panel) border bg-[linear-gradient(135deg,rgb(255_255_255_/_0.98),rgb(250_249_244_/_0.92)),var(--theme-surface)] p-5 shadow-[0_1px_0_rgb(17_17_17_/_0.04),0_28px_80px_-36px_rgb(17_17_17_/_0.22)] sm:p-8 md:grid-cols-(--layout-grid-404-main)"
      >
        <div
          class="pointer-events-none absolute -top-20 -right-12 -z-10 size-64 rounded-full bg-[rgb(217_119_6_/_0.12)] blur-[6px]"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute -bottom-24 left-[42%] -z-10 size-56 rounded-full bg-[rgb(17_17_17_/_0.06)] blur-[6px]"
          aria-hidden="true"
        >
        </div>

        <div class="grid content-center gap-5 py-1">
          <div
            class="text-content-subtle text-caption tracking-eyebrow font-mono leading-4 uppercase"
          >
            404 / Missing page
          </div>
          <div
            class="text-content-muted text-caption tracking-pill inline-flex w-fit items-center gap-2 rounded-full border border-[rgb(17_17_17_/_0.08)] bg-[rgb(255_255_255_/_0.7)] px-3 py-1.5 font-mono uppercase"
          >
            <ShieldCheck size={16} strokeWidth={1.8} />
            <span>Safe path back</span>
          </div>
          <h1
            class="max-w-measure-landing-section text-display-hero tracking-tight-hero text-balance"
          >
            Nothing here to reveal. The page is missing.
          </h1>
          <p
            class="text-content-muted max-w-measure-landing-section leading-reading text-lg text-pretty"
          >
            The link may be out of date, moved, or typed incorrectly. Your document redactor is
            still here, ready to run locally in your browser.
          </p>

          <div class="grid gap-3 pt-1 sm:flex sm:flex-wrap">
            <Button href={appUrl} size="lg">
              <span>Open the app</span>
              <ArrowRight size={16} strokeWidth={1.8} />
            </Button>
            <Button href={baseUrl} size="lg" variant="secondary">
              <Home size={16} strokeWidth={1.8} />
              <span>Go home</span>
            </Button>
          </div>

          <div class="grid gap-3 pt-1 sm:grid-cols-2 md:grid-cols-3">
            {
              helpLinks.map((link) => (
                <a
                  class="border-border text-content hover:border-border-strong flex min-h-15 items-center justify-between gap-3 rounded-2xl border bg-[rgb(255_255_255_/_0.7)] px-4 py-3 text-sm font-medium no-underline transition-[transform,border-color,background-color] duration-200 hover:-translate-y-0.5 hover:bg-[rgb(255_255_255_/_0.95)]"
                  href={link.href}
                >
                  <span>{link.label}</span>
                  <ArrowRight size={15} strokeWidth={1.7} />
                </a>
              ))
            }
          </div>
        </div>

        <div class="grid items-center max-md:order-first">
          <div
            class="grid gap-4 rounded-[1.75rem] border border-[rgb(17_17_17_/_0.08)] bg-[linear-gradient(180deg,rgb(17_17_17_/_0.98),rgb(33_33_33_/_0.95))] p-4 text-white shadow-[0_26px_70px_-38px_rgb(17_17_17_/_0.55)] sm:p-5"
          >
            <div class="flex items-center justify-between gap-3">
              <span class="text-badge tracking-label font-mono leading-4 text-white/55 uppercase"
                >Route check</span
              >
              <span
                class="text-badge tracking-chip inline-flex items-center rounded-full bg-[rgb(239_68_68_/_0.16)] px-2.5 py-1 font-mono text-[rgb(252_165_165)] uppercase"
                >Not found</span
              >
            </div>

            <div class="grid gap-3 rounded-[1.25rem] border border-white/10 bg-white/5 p-4">
              <div class="flex items-center gap-3 text-white/80">
                <FileSearch size={18} strokeWidth={1.8} />
                <span class="text-field">Requested page</span>
              </div>
              <code
                class="rounded-xl bg-white/10 px-3 py-2.5 font-mono text-xs [overflow-wrap:anywhere] text-[rgb(255_244_214)]"
                >{Astro.url.pathname}</code
              >
            </div>

            <div class="grid gap-3 rounded-[1.25rem] border border-white/10 bg-white/5 p-4">
              <div class="flex items-center justify-between gap-3">
                <span class="text-badge tracking-label font-mono leading-4 text-white/55 uppercase"
                  >Suggested next step</span
                >
                <ArrowLeft size={14} strokeWidth={1.8} />
              </div>
              <div class="grid gap-2.5">
                <div class="h-[0.72rem] w-[58%] rounded-full bg-white/15"></div>
                <div class="h-[0.72rem] rounded-full bg-white/15"></div>
                <div
                  class="h-[0.72rem] w-[84%] rounded-full bg-[linear-gradient(90deg,rgb(17_17_17_/_0.8),rgb(17_17_17_/_0.8)),linear-gradient(90deg,rgb(245_158_11_/_0.95),rgb(217_119_6_/_0.95))] shadow-[inset_0_0_0_1px_rgb(245_158_11_/_0.24)]"
                >
                </div>
                <div class="h-[0.72rem] rounded-full bg-white/15"></div>
                <div
                  class="h-[0.72rem] rounded-full bg-[linear-gradient(90deg,rgb(17_17_17_/_0.8),rgb(17_17_17_/_0.8)),linear-gradient(90deg,rgb(245_158_11_/_0.95),rgb(217_119_6_/_0.95))] shadow-[inset_0_0_0_1px_rgb(245_158_11_/_0.24)]"
                >
                </div>
                <div class="h-[0.72rem] w-[58%] rounded-full bg-white/15"></div>
              </div>
            </div>

            <ul class="leading-reading grid gap-2 pl-4 text-sm text-white/75">
              <li>Check the URL for typos.</li>
              <li>Return to the homepage.</li>
              <li>Jump straight into local PDF redaction.</li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <LandingFooterCta appUrl={appUrl} baseUrl={baseUrl} />
  </div>
</Layout>
