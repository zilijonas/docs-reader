---
import {
  ArrowLeft,
  ArrowRight,
  FileSearch,
  Home,
  ShieldCheck,
} from "lucide-react";
import Layout from "../layouts/Layout.astro";
import LandingFooterCta from "../features/landing/components/LandingFooterCta.astro";
import LandingHeader from "../features/landing/components/LandingHeader.astro";
import { SEO } from "../lib/seo";

const baseUrl = import.meta.env.BASE_URL;
const appUrl = `${baseUrl}redact`;
const helpLinks = [
  { href: `${baseUrl}faq`, label: "Read the FAQ" },
  { href: `${baseUrl}privacy`, label: "Review privacy details" },
  { href: `${baseUrl}contact`, label: "Get in touch" },
];
---

<Layout seo={SEO.notFound}>
  <div class="landing-page marketing-page not-found-page">
    <LandingHeader appUrl={appUrl} baseUrl={baseUrl} />

    <main class="page-container not-found-shell">
      <section class="not-found-hero surface-card">
        <div class="not-found-orb not-found-orb-primary" aria-hidden="true">
        </div>
        <div class="not-found-orb not-found-orb-secondary" aria-hidden="true">
        </div>

        <div class="not-found-copy">
          <div class="type-eyebrow">404 / Missing page</div>
          <div class="not-found-kicker">
            <ShieldCheck size={16} strokeWidth={1.8} />
            <span>Safe path back</span>
          </div>
          <h1 class="type-display-hero">
            Nothing here to reveal. The page is missing.
          </h1>
          <p class="type-body-lg measure-landing-section">
            The link may be out of date, moved, or typed incorrectly. Your
            document redactor is still here, ready to run locally in your
            browser.
          </p>

          <div class="not-found-actions">
            <a class="landing-button" href={appUrl}>
              <span>Open the app</span>
              <ArrowRight size={16} strokeWidth={1.8} />
            </a>
            <a class="landing-button-secondary" href={baseUrl}>
              <Home size={16} strokeWidth={1.8} />
              <span>Go home</span>
            </a>
          </div>

          <div class="not-found-links">
            {
              helpLinks.map((link) => (
                <a class="not-found-link-card" href={link.href}>
                  <span>{link.label}</span>
                  <ArrowRight size={15} strokeWidth={1.7} />
                </a>
              ))
            }
          </div>
        </div>

        <div class="not-found-visual" aria-hidden="true">
          <div class="not-found-panel">
            <div class="not-found-panel-head">
              <span class="type-data">Route check</span>
              <span class="not-found-status">Not found</span>
            </div>

            <div class="not-found-path-card">
              <div class="not-found-path-row">
                <FileSearch size={18} strokeWidth={1.8} />
                <span class="not-found-path-label">Requested page</span>
              </div>
              <code class="not-found-path-value">{Astro.url.pathname}</code>
            </div>

            <div class="not-found-doc-card">
              <div class="not-found-doc-head">
                <span class="type-data">Suggested next step</span>
                <ArrowLeft size={14} strokeWidth={1.8} />
              </div>
              <div class="not-found-doc-body">
                <div class="not-found-doc-line not-found-doc-line-short"></div>
                <div class="not-found-doc-line"></div>
                <div class="not-found-doc-line redacted"></div>
                <div class="not-found-doc-line"></div>
                <div class="not-found-doc-line redacted redacted-wide"></div>
                <div class="not-found-doc-line not-found-doc-line-short"></div>
              </div>
            </div>

            <ul class="not-found-tip-list">
              <li>Check the URL for typos.</li>
              <li>Return to the homepage.</li>
              <li>Jump straight into local PDF redaction.</li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <LandingFooterCta appUrl={appUrl} baseUrl={baseUrl} />
  </div>
</Layout>

<style>
  .not-found-page {
    background:
      radial-gradient(
        circle at top left,
        rgb(217 119 6 / 0.08),
        transparent 24rem
      ),
      radial-gradient(
        circle at top right,
        rgb(17 17 17 / 0.05),
        transparent 30rem
      ),
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--theme-canvas) 94%, white) 0%,
        var(--theme-canvas) 100%
      );
  }

  .not-found-shell {
    flex: 1 0 auto;
    display: grid;
    align-items: center;
    padding-top: clamp(2rem, 6vw, 4rem);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }

  .not-found-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.98), rgb(250 249 244 / 0.92)),
      var(--theme-surface);
    box-shadow:
      0 1px 0 rgb(17 17 17 / 0.04),
      0 28px 80px -36px rgb(17 17 17 / 0.22);
  }

  .not-found-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(6px);
    pointer-events: none;
    z-index: -1;
  }

  .not-found-orb-primary {
    top: -5rem;
    right: -3rem;
    width: 16rem;
    height: 16rem;
    background: rgb(217 119 6 / 0.12);
  }

  .not-found-orb-secondary {
    bottom: -6rem;
    left: 42%;
    width: 14rem;
    height: 14rem;
    background: rgb(17 17 17 / 0.06);
  }

  .not-found-copy,
  .not-found-visual,
  .not-found-panel,
  .not-found-doc-card,
  .not-found-path-card {
    min-width: 0;
  }

  .not-found-copy {
    display: grid;
    align-content: center;
    gap: 1.25rem;
    padding-block: clamp(0.25rem, 2vw, 1rem);
  }

  .not-found-copy h1,
  .not-found-copy p {
    margin: 0;
  }

  .not-found-kicker {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgb(17 17 17 / 0.08);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.7);
    padding: 0.4rem 0.7rem;
    font-family: var(--font-ui-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--theme-content-muted);
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.25rem;
  }

  .not-found-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.875rem;
    padding-top: 0.25rem;
  }

  .not-found-link-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 3.75rem;
    border: 1px solid var(--theme-border);
    border-radius: 1.15rem;
    background: rgb(255 255 255 / 0.7);
    padding: 0.95rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      transform 200ms var(--theme-ease-standard),
      border-color 200ms var(--theme-ease-standard),
      background-color 200ms var(--theme-ease-standard);
  }

  .not-found-link-card:hover {
    transform: translateY(-1px);
    border-color: var(--theme-border-strong);
    background: rgb(255 255 255 / 0.95);
  }

  .not-found-visual {
    display: grid;
    align-items: center;
  }

  .not-found-panel {
    display: grid;
    gap: 1rem;
    border: 1px solid rgb(17 17 17 / 0.08);
    border-radius: 1.75rem;
    background: linear-gradient(
      180deg,
      rgb(17 17 17 / 0.98),
      rgb(33 33 33 / 0.95)
    );
    padding: clamp(1rem, 3vw, 1.4rem);
    color: white;
    box-shadow: 0 26px 70px -38px rgb(17 17 17 / 0.55);
  }

  .not-found-panel-head,
  .not-found-path-row,
  .not-found-doc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .not-found-panel-head .type-data,
  .not-found-doc-head .type-data {
    color: rgb(255 255 255 / 0.55);
  }

  .not-found-status {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: rgb(239 68 68 / 0.16);
    padding: 0.35rem 0.6rem;
    font-family: var(--font-ui-mono);
    font-size: 0.65625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(252 165 165);
  }

  .not-found-path-card,
  .not-found-doc-card {
    display: grid;
    gap: 0.85rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.04);
    padding: 1rem;
  }

  .not-found-path-row {
    justify-content: flex-start;
    color: rgb(255 255 255 / 0.76);
  }

  .not-found-path-label {
    font-size: 0.8125rem;
  }

  .not-found-path-value {
    overflow-wrap: anywhere;
    border-radius: 0.9rem;
    background: rgb(255 255 255 / 0.06);
    padding: 0.75rem 0.875rem;
    font-family: var(--font-ui-mono);
    font-size: 0.75rem;
    color: rgb(255 244 214);
  }

  .not-found-doc-body {
    display: grid;
    gap: 0.65rem;
  }

  .not-found-doc-line {
    height: 0.72rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.12);
  }

  .not-found-doc-line-short {
    width: 58%;
  }

  .redacted {
    width: 84%;
    background:
      linear-gradient(90deg, rgb(17 17 17 / 0.8), rgb(17 17 17 / 0.8)),
      linear-gradient(90deg, rgb(245 158 11 / 0.95), rgb(217 119 6 / 0.95));
    box-shadow: inset 0 0 0 1px rgb(245 158 11 / 0.24);
  }

  .redacted-wide {
    width: 100%;
  }

  .not-found-tip-list {
    display: grid;
    gap: 0.625rem;
    margin: 0;
    padding-left: 1rem;
    color: rgb(255 255 255 / 0.74);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  @media (max-width: 72rem) {
    .not-found-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 60rem) {
    .not-found-hero {
      grid-template-columns: minmax(0, 1fr);
    }

    .not-found-visual {
      order: -1;
    }
  }

  @media (max-width: 40rem) {
    .not-found-shell {
      padding-top: 1.5rem;
      padding-bottom: 3rem;
    }

    .not-found-hero {
      border-radius: 1.4rem;
      padding: 1.125rem;
    }

    .not-found-links {
      grid-template-columns: minmax(0, 1fr);
    }

    .not-found-actions {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
    }

    .not-found-actions > a {
      width: 100%;
      justify-content: center;
    }

    .not-found-panel {
      border-radius: 1.35rem;
    }
  }
</style>
